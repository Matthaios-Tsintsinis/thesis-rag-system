        "    print(\"Set REGEN_TESTSET = True to regenerate.\")\n",
        "else:\n",
        "    # Convert the notebook's `documents` list to LangChain Document objects.\n",
        "    # `filename` in metadata is required by the RAGAS knowledge graph builder\n",
