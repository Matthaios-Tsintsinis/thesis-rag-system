        "#UPDATED (cache embeddings, per chunking strategy)\n",
        "# ============================================\n",
        "# 6) Embeddings and FAISS index\n",
        "# ============================================\n",
        "import faiss\n",
        "import os\n",
        "from rank_bm25 import BM25Okapi\n",
        "\n",
        "tokenized_corpus = [c[\"text\"].lower().split() for c in chunks]\n",
        "bm25 = BM25Okapi(tokenized_corpus) if CONFIG[\"use_bm25_hybrid\"] else None\n",
        "print(f\"BM25 index: {'built' if bm25 else 'disabled'} ({len(tokenized_corpus)} chunks)\")\n",
        "\n",
        "# Cache files are tagged with the chunking strategy so switching the flag in\n",
        "# CONFIG automatically uses a separate cache (no manual deletion needed).\n",
        "_strat = CONFIG[\"chunking_strategy\"]\n",
        "CACHE_EMBEDDINGS = os.path.join(CACHE_DIR, f\"embeddings_{_strat}.npy\")\n",
        "CACHE_INDEX      = os.path.join(CACHE_DIR, f\"faiss_{_strat}.index\")\n",
        "CACHE_CHUNKS     = os.path.join(CACHE_DIR, f\"chunks_{_strat}.json\")\n",
        "\n",
        "if (os.path.exists(CACHE_EMBEDDINGS)\n",
        "        and os.path.exists(CACHE_INDEX)\n",
        "        and os.path.exists(CACHE_CHUNKS)):\n",
        "    print(f\"Loading cached embeddings + chunks (strategy={_strat})...\")\n",
        "    chunk_embeddings = np.load(CACHE_EMBEDDINGS)\n",
        "    index = faiss.read_index(CACHE_INDEX)\n",
        "    with open(CACHE_CHUNKS, \"r\", encoding=\"utf-8\") as f:\n",
        "        chunks = json.load(f)\n",
        "    # Rebuild dependent maps from the cached chunks\n",
        "    doc_chunks_map = defaultdict(list)\n",
        "    for c in chunks:\n",
        "        doc_chunks_map[c[\"doc_id\"]].append(c)\n",
        "    for doc_id in doc_chunks_map:\n",
        "        doc_chunks_map[doc_id] = sorted(doc_chunks_map[doc_id], key=lambda x: x[\"chunk_id_local\"])\n",
        "    print(f\"Loaded {len(chunks)} chunks from cache.\")\n",
        "else:\n",
        "    print(f\"No cache for strategy={_strat} — computing embeddings from scratch...\")\n",
        "    chunk_texts = [c[\"text\"] for c in chunks]\n",
        "    chunk_embeddings = embedder.encode(\n",
        "        chunk_texts,\n",
        "        batch_size=16,\n",
        "        show_progress_bar=True,\n",
        "        normalize_embeddings=True,\n",
        "        convert_to_numpy=True,\n",
        "    ).astype(\"float32\")\n",
        "\n",
        "    dim = chunk_embeddings.shape[1]\n",
        "    index = faiss.IndexFlatIP(dim)\n",
        "    index.add(chunk_embeddings)\n",
        "\n",
        "    # save all three so the cache check works on next run\n",
        "    np.save(CACHE_EMBEDDINGS, chunk_embeddings)\n",
        "    faiss.write_index(index, CACHE_INDEX)\n",
        "    with open(CACHE_CHUNKS, \"w\", encoding=\"utf-8\") as f:\n",
        "        json.dump(chunks, f, ensure_ascii=False)\n",
        "    print(f\"Saved embeddings, index, and chunks to cache (strategy={_strat}).\")\n",
        "\n",
        "chunk_id_to_idx = {c[\"chunk_id\"]: i for i, c in enumerate(chunks)}\n",
        "doc_id_to_idx   = {d[\"doc_id\"]: i for i, d in enumerate(documents)}\n",
        "\n",
        "print(\"Embeddings shape:\", chunk_embeddings.shape)\n"
      ]
